<script>
  import { initFeedLoader } from '../lib/feed-loader';
  import { initMaintainerLoader } from '../lib/maintainer-loader';
  import { searchPeople, preloadSearchIndex } from '../lib/search';

  const timelineFeed = document.getElementById('timeline-feed') as HTMLElement;
  const staticCount = parseInt(timelineFeed?.dataset.staticCount ?? '200', 10);
  const baseUrl = timelineFeed?.dataset.baseUrl ?? '/people-website';

  // Expose base for feed-loader
  document.documentElement.dataset.base = baseUrl;

  // Preload search index in background
  preloadSearchIndex(import.meta.env.BASE_URL);

  // Fetch landscape logos once — shared by both feed-loader and maintainer-loader.
  // Use a mutable object so feed-loader can start immediately and logos fill in async.
  const logos: Record<string, string> = {};
  const logosPromise: Promise<void> =
    fetch(`${baseUrl}/data/landscape_logos.json`)
      .then(r => r.json())
      .then((resolved: Record<string, string>) => { Object.assign(logos, resolved); })
      .catch(() => {/* logos stay empty — onerror handlers hide broken imgs */});

  // Kick off infinite scroll for the main timeline feed immediately — no logo gate.
  // changelog.json (4.1MB) takes longer than logos (476KB) so they arrive in parallel.
  initFeedLoader(staticCount, logos, applyFilters);

  // Defer maintainer data fetch until the Maintainers tab is first activated.
  let maintainerInitialized = false;
  function maybeInitMaintainer(tab: string) {
    if (tab === 'maintainers' && !maintainerInitialized) {
      maintainerInitialized = true;
      const maintainerStaticCount = document.getElementById('maintainer-feed')
        ?.querySelectorAll('.maintainer-card').length ?? 0;
      // Pass the shared logos object — will be populated by the time maintainers tab opens.
      logosPromise.then(() => initMaintainerLoader(maintainerStaticCount, logos));
    }
  }

  // Hook into tab buttons to trigger deferred init.
  document.querySelectorAll<HTMLButtonElement>('.section-link[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => maybeInitMaintainer(btn.dataset.tab ?? ''));
  });
  // Also check the restored tab on page load.
  maybeInitMaintainer(localStorage.getItem('active-tab') ?? 'everyone');

  // Hero card confetti: fires on click anywhere except the name link.
  document.addEventListener('click', (e: MouseEvent) => {
    const card = (e.target as Element)?.closest('.hero-card');
    if (!card) return;
    // Let name link navigate normally — confetti fires for everything else.
    if ((e.target as Element)?.closest('.hero-name')) return;
    e.preventDefault();
    card.classList.add('pressing');
    setTimeout(() => card.classList.remove('pressing'), 200);
    const isMemorial = (card as HTMLElement).dataset.category === 'Memorial';
    import('../lib/hero-confetti').then(({ fireConfetti, fireHearts }) => {
      if (isMemorial) fireHearts(card);
      else fireConfetti(card);
    });
  });

  // Preload confetti logos on first hover over any hero card (improves logo burst on click).
  document.addEventListener('mouseover', (e: MouseEvent) => {
    const card = (e.target as Element)?.closest('.hero-card');
    if (card) {
      import('../lib/hero-confetti').then(({ preloadOnHover }) => preloadOnHover(card));
    }
  }, { once: true });

  // Staff minicards: starburst on click (fire & let navigation proceed).
  document.addEventListener('click', (e: MouseEvent) => {
    const card = (e.target as Element)?.closest('.staff-support-card');
    if (!card) return;
    import('../lib/hero-confetti').then(({ fireStarburst }) => fireStarburst(card));
  });

  // PersonCard / MaintainerCard: fountain using the card's accent color.
  document.addEventListener('click', (e: MouseEvent) => {
    const card = (e.target as Element)?.closest('.person-card, .maintainer-card');
    if (!card) return;
    // Let normal link navigation happen (name, handle, company) — confetti fires alongside.
    import('../lib/hero-confetti').then(({ fireFountain }) => fireFountain(card));
  });
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const typeFilter  = document.getElementById('type-filter') as HTMLSelectElement;
  const catFilter   = document.getElementById('category-filter') as HTMLSelectElement;
  const filterCount = document.getElementById('filter-count');

  function applyFilters() {
    const query = searchInput?.value.toLowerCase() ?? '';
    const type  = typeFilter?.value ?? '';
    const cat   = catFilter?.value ?? '';

    // Re-query each time to include dynamically loaded cards
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#timeline-feed .person-card'));

    let visible = 0;
    for (const card of cards) {
      const text = card.textContent?.toLowerCase() ?? '';
      const cardType = card.dataset.type ?? '';
      const cardCat  = card.dataset.category ?? '';

      const matchSearch = !query || text.includes(query);
      const matchType   = !type  || cardType === type;
      const matchCat    = !cat   || cardCat.includes(cat);

      const show = matchSearch && matchType && matchCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }

    for (const group of document.querySelectorAll<HTMLElement>('.day-group')) {
      const visibleCards = group.querySelectorAll<HTMLElement>('.person-card:not([style*="display: none"])');
      (group as HTMLElement).style.display = visibleCards.length ? '' : 'none';
    }

    if (filterCount) {
      filterCount.textContent = (query || type || cat)
        ? `Showing ${visible} of ${cards.length}`
        : '';
    }
  }

  searchInput?.addEventListener('input', applyFilters);
  typeFilter?.addEventListener('change', applyFilters);
  catFilter?.addEventListener('change', applyFilters);

  // ── Global search (queries all people via minisearch index) ───────────
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;

  searchInput?.removeEventListener('input', applyFilters);
  searchInput?.addEventListener('input', async () => {
    const q = searchInput.value.trim();
    const overlay = document.getElementById('search-results-overlay')!;

    if (!q) {
      overlay.style.display = 'none';
      // Re-trigger current active tab to restore proper feed state
      document.querySelector<HTMLButtonElement>('.section-link.active')?.click();
      applyFilters();
      return;
    }

    // Hide main feed areas while showing search overlay
    document.getElementById('timeline-feed')!.style.display = 'none';
    document.querySelectorAll<HTMLElement>('.alpha-feed').forEach(el => { el.style.display = 'none'; });
    const memFeed = document.getElementById('memorial-feed');
    if (memFeed) memFeed.style.display = 'none';
    const maintFeed = document.getElementById('maintainer-feed');
    if (maintFeed) maintFeed.style.display = 'none';
    document.querySelectorAll<HTMLElement>('[data-tab-heroes]').forEach(el => { el.style.display = 'none'; });
    overlay.style.display = '';

    if (searchTimeout) clearTimeout(searchTimeout);
    searchTimeout = setTimeout(async () => {
      const results = await searchPeople(q, import.meta.env.BASE_URL);
      const list = document.getElementById('search-results-list')!;
      if (results.length === 0) {
        list.innerHTML = '<p class="search-no-results">No people found matching your search.</p>';
      } else {
        list.innerHTML = results.map(p => `
          <a class="search-result-item" href="${p.github ?? '#'}" target="_blank" rel="noopener noreferrer">
            <img class="search-result-avatar" src="${p.avatarUrl || p.imageUrl || ''}" alt="${p.name}" loading="lazy" onerror="this.style.display='none'" />
            <div class="search-result-info">
              <span class="search-result-name">${p.countryFlag ? p.countryFlag + ' ' : ''}${p.name}</span>
              ${p.handle ? `<span class="search-result-handle">@${p.handle}</span>` : ''}
              ${p.company ? `<span class="search-result-company">${p.company}</span>` : ''}
              <span class="search-result-cats">${(p.category ?? []).slice(0, 2).join(' · ')}</span>
            </div>
          </a>
        `).join('');
      }
    }, 200);
  });

  document.getElementById('clear-search-btn')?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    searchInput?.dispatchEvent(new Event('input'));
    searchInput?.focus();
  });

  // ── Vim-style card navigation ──────────────────────────────────────────
  //
  // Navigable elements: .person-card AND .hero-card.
  //
  // Visibility is determined by offsetParent !== null, which returns null whenever
  // the element or any ancestor has display:none. This correctly excludes:
  //   - Cards inside hidden tab alpha-feeds (display:none on the feed parent)
  //   - Hero cards inside hidden [data-tab-heroes] sections
  //   - Filtered-out person cards (display:none on the card itself)
  const visibleCards = () =>
    Array.from(document.querySelectorAll<HTMLElement>('.person-card, .hero-card'))
      .filter(c => c.offsetParent !== null && c.style.display !== 'none');

  let focusedIdx = -1;

  // Hero card confetti: click any hero card to trigger pinata explosion.
  document.addEventListener('click', (e: MouseEvent) => {
    const card = (e.target as Element)?.closest('.hero-card');
    if (card) fireConfetti(card);
  });

  function resetFocus() {
    document.querySelectorAll<HTMLElement>('.keyboard-focused')
      .forEach(c => c.classList.remove('keyboard-focused'));
    focusedIdx = -1;
  }

  function focusCard(idx: number) {
    const all = visibleCards();
    if (all.length === 0) return;
    focusedIdx = Math.max(0, Math.min(idx, all.length - 1));
    all.forEach((c, i) => c.classList.toggle('keyboard-focused', i === focusedIdx));
    all[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  // Reset focus state whenever the active tab changes so j/k starts from scratch.
  document.querySelectorAll<HTMLButtonElement>('.section-link[data-tab]').forEach(btn => {
    btn.addEventListener('click', resetFocus);
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const active = document.activeElement as HTMLElement;
    const inInput = active?.tagName === 'INPUT' || active?.tagName === 'TEXTAREA' || active?.tagName === 'SELECT';

    // '/' focuses search — skip if already focused there to avoid preventDefault swallowing the char
    if (e.key === '/') {
      if (active !== searchInput) { e.preventDefault(); searchInput?.focus(); }
      return;
    }

    // '?' opens help — only when not typing in an input
    if (e.key === '?' && !inInput) {
      document.getElementById('keyboard-help-modal')?.classList.add('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
      return;
    }

    if (e.key === 'Escape') {
      document.getElementById('keyboard-help-modal')?.classList.remove('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.remove('visible');
      if (searchInput && searchInput.value) {
        searchInput.value = '';
        searchInput.dispatchEvent(new Event('input'));
      }
      (document.activeElement as HTMLElement)?.blur();
      resetFocus();
      return;
    }

    if (!inInput) {
      if (e.key === 's') { e.preventDefault(); searchInput?.focus(); }
      if (e.key === 't') { (window as unknown as { toggleTheme?: () => void }).toggleTheme?.(); }
      if (e.key === 'j') { e.preventDefault(); focusCard(focusedIdx + 1); }
      if (e.key === 'k') { e.preventDefault(); focusCard(focusedIdx - 1); }
      if (e.key === 'h') { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      if (e.key === ' ' && !e.shiftKey) { e.preventDefault(); window.scrollBy({ top: window.innerHeight * 0.85, behavior: 'smooth' }); }
      if (e.key === ' ' &&  e.shiftKey) { e.preventDefault(); window.scrollBy({ top: -window.innerHeight * 0.85, behavior: 'smooth' }); }
      if (e.key === 'Tab') {
        const tabBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.section-link[data-tab]'));
        if (tabBtns.length === 0) return;
        e.preventDefault();
        const activeBtn = tabBtns.find(b => b.classList.contains('active'));
        const cur = activeBtn ? tabBtns.indexOf(activeBtn) : 0;
        const next = e.shiftKey
          ? (cur - 1 + tabBtns.length) % tabBtns.length
          : (cur + 1) % tabBtns.length;
        tabBtns[next].click();
        tabBtns[next].scrollIntoView({ inline: 'nearest', block: 'nearest' });
      }
      if (e.key === 'o' || e.key === 'Enter') {
        const all = visibleCards();
        const card = all[focusedIdx];
        const link = card?.querySelector<HTMLAnchorElement>('a[href]');
        if (link) { e.preventDefault(); window.open(link.href, '_blank', 'noopener'); }
      }
      if (e.key === '[') {
        window.location.href = 'https://castrojo.github.io/endusers-website/';
      } else if (e.key === ']') {
        window.location.href = 'https://castrojo.github.io/projects-website/';
      }
    }
  });
</script>

<style is:global>
  .person-card.keyboard-focused,
  .hero-card.keyboard-focused {
    outline: 2px solid var(--color-accent-emphasis);
    outline-offset: 2px;
  }
</style>
