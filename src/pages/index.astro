---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

import PeopleLayout from '../layouts/PeopleLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import MemorialCard from '../components/MemorialCard.astro';
import HeroCard from '../components/HeroCard.astro';
import MaintainerCard from '../components/MaintainerCard.astro';
import InfoBox from '../components/InfoBox.astro';
import KubeConBanner from '../components/KubeConBanner.astro';
import { getActiveBanners } from '../lib/banners';

import changelogRaw from '../data/changelog.json';
import landscapeLogosRaw from '../data/landscape_logos.json';
import memorialList from '../data/memorial.json';

// Load maintainers — generated by Go backend from cncf/foundation project-maintainers.csv.
// Falls back to empty array if the file hasn't been generated yet (first build).
interface SafeMaintainer {
  name: string;
  handle: string;
  company?: string;
  location?: string;
  countryFlag?: string;
  bio?: string;
  projects: string[];
  projectDetails?: { name: string; maturity: string }[];
  maturity: string;
  ownersUrl?: string;
  logoUrl?: string;
  yearsContributing?: number;
  updatedAt?: string;
}
let maintainerList: SafeMaintainer[] = [];
try {
  const maintainersPath = resolve('./src/data/maintainers.json');
  maintainerList = JSON.parse(readFileSync(maintainersPath, 'utf-8')) as SafeMaintainer[];
} catch {
  // maintainers.json not yet generated — skip maintainers tab silently
}

interface Change {
  field: string;
  from: string;
  to: string;
}

interface Person {
  name: string;
  handle?: string;
  github?: string;
  imageUrl?: string;
  bio?: string;
  pronouns?: string;
  company?: string;
  companyLandscapeUrl?: string;
  location?: string;
  linkedin?: string;
  twitter?: string;
  youtube?: string;
  website?: string;
  bluesky?: string;
  mastodon?: string;
  certDirectory?: string;
  category: string[];
  projects?: string[];
  avatarUrl?: string;
  contributions?: number;
  followers?: number;
  publicRepos?: number;
  countryFlag?: string;
  primaryBadge?: string;
}

interface Event {
  id: string;
  type: 'added' | 'removed' | 'updated';
  timestamp: string;
  person: Person;
  changes?: Change[];
}

const STATIC_COUNT = 200;

const events = changelogRaw as Event[];
const staticEvents = events.slice(0, STATIC_COUNT);
const landscapeLogos = landscapeLogosRaw as Record<string, string>;

function dateHeader(ts: string): string {
  const d = new Date(ts);
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}

const grouped: Map<string, Event[]> = new Map();
for (const e of staticEvents) {
  const key = dateHeader(e.timestamp);
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(e);
}

const baseUrl = (import.meta.env.BASE_URL as string).replace(/\/*$/, '/');
const feedUrl = `${baseUrl}feed.xml`;

const banners = await getActiveBanners();

const CATEGORY_ORDER = [
  'Kubestronaut',
  'Golden-Kubestronaut',
  'Ambassadors',
  'Technical Oversight Committee',
  'End User TAB',
  'Governing Board',
  'Staff',
  'Marketing Committee',
];
const CATEGORY_LABELS: Record<string, string> = {
  'Kubestronaut':                  'Kubestronauts',
  'Golden-Kubestronaut':           'Golden Kubestronauts',
  'Ambassadors':                   'Ambassadors',
  'Technical Oversight Committee': 'TOC Members',
  'End User TAB':                  'End User TAB',
  'Governing Board':               'Governing Board',
  'Staff':                         'Staff',
  'Marketing Committee':           'Marketing Committee',
};

interface SiteStats {
  total: number;
  added: number;
  removed: number;
  updated: number;
  countries: number;
  companies: number;
  categories: Record<string, number>;
}

let siteStats: SiteStats = {
  total: 0, added: 0, removed: 0, updated: 0,
  countries: 0, companies: 0, categories: {},
};
try {
  const statsPath = resolve('./src/data/stats.json');
  siteStats = JSON.parse(readFileSync(statsPath, 'utf-8')) as SiteStats;
} catch {
  // stats.json not yet generated — fall back to computing from events
  const uniquePeople = new Map<string, Person>();
  for (const e of events) {
    const key = e.person.github ?? e.person.name;
    if (!uniquePeople.has(key)) uniquePeople.set(key, e.person);
  }
  const peopleList = [...uniquePeople.values()];
  const countrySet = new Set(peopleList.map(p => (p.location ?? '').split(',').at(-1)?.trim() ?? '').filter(Boolean));
  const companySet = new Set(peopleList.map(p => p.company?.trim() ?? '').filter(Boolean));
  siteStats = {
    total: peopleList.length,
    added: events.filter(e => e.type === 'added').length,
    removed: events.filter(e => e.type === 'removed').length,
    updated: events.filter(e => e.type === 'updated').length,
    countries: countrySet.size,
    companies: companySet.size,
    categories: Object.fromEntries(
      CATEGORY_ORDER.map(cat => [cat, peopleList.filter(p => (p.category ?? []).includes(cat)).length])
    ),
  };
}

const categoryCounts = siteStats.categories;
const stats = { total: siteStats.total, added: siteStats.added, removed: siteStats.removed, updated: siteStats.updated };
const countries = siteStats.countries;
const companies = siteStats.companies;

const categories = [...new Set(events.flatMap(e => e.person.category ?? []))].sort();

// Per-category summary stats for the info banners
const TAB_CATEGORY_FILTER: Record<string, (cats: string[]) => boolean> = {
  'everyone':            ()    => true,
  'ambassadors':         cats  => cats.includes('Ambassadors'),
  'kubestronauts':       cats  => cats.includes('Kubestronaut'),
  'golden-kubestronauts': cats => cats.includes('Golden-Kubestronaut'),
  'toc':                 cats  => cats.includes('Technical Oversight Committee'),
  'tab':                 cats  => cats.includes('End User TAB'),
  'governing-board':     cats  => cats.includes('Governing Board'),
  'staff':               cats  => cats.includes('Staff'),
};

function categoryStats(filterFn: (cats: string[]) => boolean) {
  const people = events
    .filter(e => filterFn(e.person.category ?? []))
    .map(e => e.person);
  const unique = new Map(people.map(p => [p.github ?? p.name, p]));
  const ps = [...unique.values()];
  const countries = new Set(
    ps.map(p => (p.location ?? '').split(',').at(-1)?.trim() ?? '').filter(Boolean)
  ).size;
  const projects = new Set(ps.flatMap(p => p.projects ?? [])).size;
  const orgs = new Set(ps.map(p => p.company ?? '').filter(Boolean)).size;
  return { total: ps.length, countries, projects, orgs };
}

const tabStats = Object.fromEntries(
  Object.entries(TAB_CATEGORY_FILTER).map(([tab, fn]) => [tab, categoryStats(fn)])
);

// Alphabetical tabs — deduplicated (most recent event per person), sorted by name
const ALPHA_TABS: Record<string, (cats: string[]) => boolean> = {
  'toc':             cats => cats.includes('Technical Oversight Committee'),
  'tab':             cats => cats.includes('End User TAB'),
  'governing-board': cats => cats.includes('Governing Board'),
  'staff':           cats => cats.includes('Staff'),
};

function alphabeticalPeople(filterFn: (cats: string[]) => boolean): Event[] {
  // events is newest-first; first occurrence = most recent event per person
  const seen = new Map<string, Event>();
  for (const e of events) {
    const key = e.person.github ?? e.person.name;
    if (!seen.has(key) && filterFn(e.person.category ?? [])) {
      seen.set(key, e);
    }
  }
  return [...seen.values()].sort((a, b) => a.person.name.localeCompare(b.person.name));
}

const alphaFeeds = Object.fromEntries(
  Object.entries(ALPHA_TABS).map(([tab, fn]) => [tab, alphabeticalPeople(fn)])
);

// ── Heroes of the Day ──────────────────────────────────────────────────────
// Three hero cards displayed daily: Ambassador, Kubestronaut, Golden Kubestronaut.
// Each pool is sorted by a stable djb2 hash of the person's name so the daily
// rotation appears random but every person in the pool gets a turn before any
// repeat. dayIndex mod poolSize guarantees full coverage.

const HERO_EXCLUDED_CATS = new Set([
  'Staff', 'Governing Board', 'Technical Oversight Committee',
  'End User TAB', 'Marketing Committee',
]);

function djb2(str: string): number {
  let h = 5381;
  for (let i = 0; i < str.length; i++) {
    h = ((h << 5) + h + str.charCodeAt(i)) & 0x7fffffff;
  }
  return h;
}

const heroPools: Record<string, Person[]> = {
  'Ambassadors': [],
  'Kubestronaut': [],
  'Golden-Kubestronaut': [],
};

{
  const seen = new Set<string>();
  for (const e of events) {
    if (e.type !== 'added') continue;
    const p = e.person;
    const cats = p.category ?? [];
    if (cats.some(c => HERO_EXCLUDED_CATS.has(c))) continue;
    const badge = p.primaryBadge ?? '';
    if (!(badge in heroPools)) continue;
    const key = p.handle ?? p.name;
    if (seen.has(key)) continue;
    seen.add(key);
    heroPools[badge].push(p);
  }
  for (const pool of Object.values(heroPools)) {
    pool.sort((a, b) => djb2(a.name) - djb2(b.name));
  }
}

const heroDayIndex = Math.floor(Date.now() / 86_400_000);
const heroAmbassador  = heroPools['Ambassadors'].length
  ? heroPools['Ambassadors'][heroDayIndex % heroPools['Ambassadors'].length]
  : null;
const heroKubestronaut = heroPools['Kubestronaut'].length
  ? heroPools['Kubestronaut'][heroDayIndex % heroPools['Kubestronaut'].length]
  : null;
const heroGolden = heroPools['Golden-Kubestronaut'].length
  ? heroPools['Golden-Kubestronaut'][heroDayIndex % heroPools['Golden-Kubestronaut'].length]
  : null;

// Maintainer hero pool — sorted by djb2 hash for stable daily rotation.
const maintainersSorted = [...maintainerList].sort((a, b) => djb2(a.name) - djb2(b.name));
const heroMaintainer = maintainersSorted.length
  ? maintainersSorted[heroDayIndex % maintainersSorted.length]
  : null;

// Sort by UpdatedAt descending (most recently changed first).
const maintainerSorted = [...maintainerList].sort((a, b) => {
  const aTime = a.updatedAt ? new Date(a.updatedAt).getTime() : 0;
  const bTime = b.updatedAt ? new Date(b.updatedAt).getTime() : 0;
  return bTime - aTime;
});
const maintainerAlpha = maintainerSorted;
const MAINTAINER_STATIC = 20;

// Maintainer stats for sidebar
const maintainerProjects = new Set(maintainerList.flatMap(m => m.projects)).size;
const maintainerByMaturity: Record<string, number> = {};
for (const m of maintainerList) {
  const mat = m.maturity || 'Unknown';
  maintainerByMaturity[mat] = (maintainerByMaturity[mat] ?? 0) + 1;
}
---

<PeopleLayout pageTitle="CNCF People" feedUrl={feedUrl}>
  <div slot="search" class="search-bar">
    <input
      type="search"
      id="search-input"
      placeholder="Search by name, company, or location…"
      class="search-input"
      autocomplete="off"
    />
  </div>

  <Fragment slot="sidebar">
    <InfoBox
      title="About"
      description="Live activity feed for cncf/people — who's joining, leaving, or updating their profile in the CNCF community."
      links={[
        { text: 'RSS Feed', url: feedUrl, rss: true },
        { text: 'cncf/people on GitHub', url: 'https://github.com/cncf/people', external: true },
        { text: 'castrojo/people-website', url: 'https://github.com/castrojo/people-website', external: true },
        { text: 'CNCF Releases (Firehose)', url: 'https://castrojo.github.io/firehose/', external: true },
      ]}
    />

    {banners.length > 0 && <KubeConBanner banners={banners} />}

    <div class="stats">
      <h2 class="sidebar-heading stats-heading">Community</h2>
      <div class="stats-list">
        <div class="stat-row stat-row-total">
          <span class="stat-row-label">Total People</span>
          <span class="stat-row-value">{stats.total.toLocaleString()}</span>
        </div>
        <div class="stat-row-divider"></div>
        {CATEGORY_ORDER.filter(cat => categoryCounts[cat] > 0).map(cat => (
          <div class="stat-row">
            <span class="stat-row-label">{CATEGORY_LABELS[cat]}</span>
            <span class="stat-row-value">{categoryCounts[cat].toLocaleString()}</span>
          </div>
        ))}
        <div class="stat-row-divider"></div>
        <div class="stat-row">
          <span class="stat-row-label">Countries</span>
          <span class="stat-row-value">{countries.toLocaleString()}</span>
        </div>
        <div class="stat-row">
          <span class="stat-row-label">Organizations</span>
          <span class="stat-row-value">{companies.toLocaleString()}</span>
        </div>
      </div>
    </div>

    {maintainerList.length > 0 && (
      <div class="stats stats-maintainers" id="sidebar-maintainer-stats">
        <h2 class="sidebar-heading stats-heading">Maintainers</h2>
        <div class="stats-list">
          <div class="stat-row stat-row-total">
            <span class="stat-row-label">Total Maintainers</span>
            <span class="stat-row-value">{maintainerList.length.toLocaleString()}</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">Projects</span>
            <span class="stat-row-value">{maintainerProjects.toLocaleString()}</span>
          </div>
          <div class="stat-row-divider"></div>
          {(['Graduated', 'Incubating', 'Sandbox'] as const).filter(m => maintainerByMaturity[m]).map(m => (
            <div class="stat-row">
              <span class="stat-row-label">{m}</span>
              <span class="stat-row-value">{(maintainerByMaturity[m] ?? 0).toLocaleString()}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="sidebar-section">
      <h2 class="sidebar-heading">Filters</h2>
      <div class="filter-controls">
        <select id="type-filter" class="filter-select">
          <option value="">All people</option>
          <option value="added">Joined</option>
          <option value="removed">Left</option>
          <option value="updated">Updated</option>
        </select>
        <select id="category-filter" class="filter-select">
          <option value="">All categories</option>
          {categories.map(cat => <option value={cat.toLowerCase()}>{cat}</option>)}
        </select>
      </div>
      <p id="filter-count" class="filter-count"></p>
    </div>

    <div class="sidebar-section made-with-love">
      <p>Made with <strong>&lt;3</strong> by your CNCF Projects Team</p>
    </div>
  </Fragment>

  <div id="feed" class="feed">
    <!-- Per-tab summary banners (shown/hidden by tab JS) -->
    {Object.entries(tabStats).map(([tab, s]) => (
      <div class="category-summary" data-tab-summary={tab} style={tab !== 'everyone' ? 'display:none' : ''}>
        <span>
          <strong>{s.total.toLocaleString()}</strong> {s.total === 1 ? 'individual' : 'individuals'}
          {s.countries > 0 && <> across <strong>{s.countries}</strong> {s.countries === 1 ? 'country' : 'countries'}</>}
          {s.projects > 0 && <>, working on <strong>{s.projects}</strong> {s.projects === 1 ? 'project' : 'projects'}</>}
          {s.orgs > 0 && <>, representing <strong>{s.orgs}</strong> {s.orgs === 1 ? 'organization' : 'organizations'}</>}.
        </span>
      </div>
    ))}
    {maintainerList.length > 0 && (
      <div class="category-summary" id="maintainer-summary" style="display:none">
        <span>
          <strong>{maintainerList.length.toLocaleString()}</strong> maintainers across <strong>{maintainerProjects.toLocaleString()}</strong> projects — Graduated, Incubating, and Sandbox.
        </span>
      </div>
    )}

    <!-- Heroes of the Day: one spotlight per role, rotating daily -->
    {(heroAmbassador || heroKubestronaut || heroGolden || heroMaintainer) && (
      <section id="heroes-section" class="heroes-section">
        <h2 class="heroes-heading">Heroes of the Day</h2>
        <div class="heroes-grid">
          {heroAmbassador && (
            <HeroCard
              person={heroAmbassador}
              label="Ambassador"
              categoryKey="Ambassadors"
              baseUrl={baseUrl}
            />
          )}
          {heroKubestronaut && (
            <HeroCard
              person={heroKubestronaut}
              label="Kubestronaut"
              categoryKey="Kubestronaut"
              baseUrl={baseUrl}
            />
          )}
          {heroGolden && (
            <HeroCard
              person={heroGolden}
              label="Golden Kubestronaut"
              categoryKey="Golden-Kubestronaut"
              baseUrl={baseUrl}
            />
          )}
          {heroMaintainer && (
            <HeroCard
              person={{ ...heroMaintainer, imageUrl: heroMaintainer.logoUrl, avatarUrl: `https://avatars.githubusercontent.com/${heroMaintainer.handle}` }}
              label="Maintainer"
              categoryKey="Maintainer"
              baseUrl={baseUrl}
            />
          )}
        </div>
      </section>
    )}

    <!-- Timeline feed: recent-first, date-grouped (hidden for alpha tabs) -->
    <div id="timeline-feed" data-static-count={STATIC_COUNT} data-base-url={baseUrl.replace(/\/$/, '')}>
      {[...grouped.entries()].map(([date, dayEvents]) => (
        <section class="day-group" data-date={date}>
          <h2 class="day-header">{date}</h2>
          {dayEvents.map(event => (
            <PersonCard
              id={event.id}
              type={event.type}
              timestamp={event.timestamp}
              person={event.person}
              changes={event.changes}
              landscapeLogos={landscapeLogos}
            />
          ))}
        </section>
      ))}

      {staticEvents.length === 0 && (
        <div class="empty-state">
          <p>No activity yet — check back after the first daily sync.</p>
        </div>
      )}
    </div>

    <!-- Alpha feeds: deduplicated, alphabetical (shown only for toc/tab/staff tabs) -->
    {Object.entries(alphaFeeds).map(([tab, tabEvents]) => (
      <div id={`alpha-feed-${tab}`} class="alpha-feed" style="display:none" data-alpha-tab={tab}>
        {tabEvents.map(event => (
          <PersonCard
            id={`alpha-${event.id}`}
            type={event.type}
            timestamp={event.timestamp}
            person={event.person}
            changes={event.changes}
            landscapeLogos={landscapeLogos}
          />
        ))}
      </div>
    ))}

    <!-- Memorial feed (hidden until Memorial tab is selected) -->
    <div id="memorial-feed" style="display:none">
      <p class="memorial-intro">In memory of members of our community who have passed. Their contributions continue to shape the CNCF ecosystem.</p>
      {memorialList.map(person => (
        <MemorialCard person={person} />
      ))}
    </div>

    <!-- Maintainers feed (hidden until Maintainers tab is selected) -->
    {maintainerAlpha.length > 0 && (
      <div id="maintainer-feed" style="display:none" data-alpha-tab="maintainers">
        {maintainerAlpha.slice(0, MAINTAINER_STATIC).map(m => (
          <MaintainerCard
            maintainer={m}
            projectLogos={Object.fromEntries(
              m.projects.map(p => [p, (landscapeLogosRaw as Record<string, string>)[p] ?? (landscapeLogosRaw as Record<string, string>)[p.toLowerCase()] ?? ''])
            )}
          />
        ))}
      </div>
    )}
  </div>
</PeopleLayout>

<style>
  /* Heroes of the Day */
  .heroes-section {
    margin-bottom: 2rem;
  }

  .heroes-heading {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-secondary);
    margin-bottom: 0.85rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border-default);
  }

  .heroes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .heroes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .heroes-grid {
      grid-template-columns: 1fr;
    }
  }

  .category-summary {
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-left: 3px solid var(--color-accent-emphasis);
    border-radius: 6px;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .category-summary strong { color: var(--color-text-primary); }
  .memorial-intro {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-left: 3px solid #6b7280;
    border-radius: 6px;
  }

  .search-bar { width: 100%; }
  .search-input {
    width: 100%;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--color-accent-emphasis); }
  .search-input::placeholder { color: var(--color-text-tertiary); }

  .filter-controls { display: flex; flex-direction: column; gap: 0.5rem; }
  .filter-select {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    background: var(--color-bg-default);
    color: var(--color-text-primary);
    font-size: 0.875rem;
    cursor: pointer;
  }
  .filter-count {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    text-align: center;
    min-height: 1.25rem;
  }

  /* Stats box */
  .stats {
    background: var(--color-bg-default);
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
  }
  .stats-heading { margin-bottom: 0.75rem; }
  .stats-list { display: flex; flex-direction: column; gap: 0; }
  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.35rem 0;
    font-size: 0.875rem;
  }
  .stat-row-total {
    font-weight: 600;
    font-size: 0.9375rem;
  }
  .stat-row-label { color: var(--color-text-secondary); }
  .stat-row-total .stat-row-label { color: var(--color-text-primary); }
  .stat-row-value { font-weight: 600; color: var(--color-accent-emphasis); font-variant-numeric: tabular-nums; }
  .stat-row-total .stat-row-value { font-size: 1.25rem; }
  .stat-row-divider { height: 1px; background: var(--color-border-default); margin: 0.4rem 0; }

  /* Made with love box */
  .made-with-love { text-align: center; }
  .made-with-love p { color: var(--color-text-secondary); font-size: 0.875rem; margin: 0; }

  .day-group { margin-bottom: 2rem; }
  .day-header {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border-default);
    margin-bottom: 1rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-default);
    border: 1px solid var(--color-border-default);
    border-radius: 8px;
  }
</style>

<script>
  import { initFeedLoader } from '../lib/feed-loader';
  import { initMaintainerLoader } from '../lib/maintainer-loader';

  const timelineFeed = document.getElementById('timeline-feed') as HTMLElement;
  const staticCount = parseInt(timelineFeed?.dataset.staticCount ?? '200', 10);
  const baseUrl = timelineFeed?.dataset.baseUrl ?? '/people-website';

  // Expose base for feed-loader
  document.documentElement.dataset.base = baseUrl;

  // Fetch landscape logos once and kick off infinite scroll
  fetch(`${baseUrl}/data/landscape_logos.json`)
    .then(r => r.json())
    .then((logos: Record<string, string>) => initFeedLoader(staticCount, logos, applyFilters))
    .catch(() => initFeedLoader(staticCount, {}, applyFilters));

  // Kick off maintainer lazy-loader
  const maintainerStaticCount = document.getElementById('maintainer-feed')?.querySelectorAll('.maintainer-card').length ?? 0;
  initMaintainerLoader(maintainerStaticCount);

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const typeFilter  = document.getElementById('type-filter') as HTMLSelectElement;
  const catFilter   = document.getElementById('category-filter') as HTMLSelectElement;
  const filterCount = document.getElementById('filter-count');

  function applyFilters() {
    const query = searchInput?.value.toLowerCase() ?? '';
    const type  = typeFilter?.value ?? '';
    const cat   = catFilter?.value ?? '';

    // Re-query each time to include dynamically loaded cards
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#timeline-feed .person-card'));

    let visible = 0;
    for (const card of cards) {
      const text = card.textContent?.toLowerCase() ?? '';
      const cardType = card.dataset.type ?? '';
      const cardCat  = card.dataset.category ?? '';

      const matchSearch = !query || text.includes(query);
      const matchType   = !type  || cardType === type;
      const matchCat    = !cat   || cardCat.includes(cat);

      const show = matchSearch && matchType && matchCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }

    for (const group of document.querySelectorAll<HTMLElement>('.day-group')) {
      const visibleCards = group.querySelectorAll<HTMLElement>('.person-card:not([style*="display: none"])');
      (group as HTMLElement).style.display = visibleCards.length ? '' : 'none';
    }

    if (filterCount) {
      filterCount.textContent = (query || type || cat)
        ? `Showing ${visible} of ${cards.length}`
        : '';
    }
  }

  searchInput?.addEventListener('input', applyFilters);
  typeFilter?.addEventListener('change', applyFilters);
  catFilter?.addEventListener('change', applyFilters);

  // ── Vim-style card navigation ──────────────────────────────────────────
  const visibleCards = () =>
    Array.from(document.querySelectorAll<HTMLElement>('.person-card'))
      .filter(c => c.style.display !== 'none');

  let focusedIdx = -1;

  function focusCard(idx: number) {
    const all = visibleCards();
    if (all.length === 0) return;
    focusedIdx = Math.max(0, Math.min(idx, all.length - 1));
    all.forEach((c, i) => c.classList.toggle('keyboard-focused', i === focusedIdx));
    all[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const active = document.activeElement as HTMLElement;
    const inInput = active?.tagName === 'INPUT' || active?.tagName === 'SELECT';

    if (!inInput) {
      if (e.key === '/' || e.key === 's') { e.preventDefault(); searchInput?.focus(); }
      if (e.key === 't') { (window as unknown as { toggleTheme?: () => void }).toggleTheme?.(); }
      if (e.key === '?') {
        document.getElementById('keyboard-help-modal')?.classList.add('visible');
        document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
      }
      if (e.key === 'j') { e.preventDefault(); focusCard(focusedIdx + 1); }
      if (e.key === 'k') { e.preventDefault(); focusCard(focusedIdx - 1); }
      if (e.key === 'h') { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      if (e.key === ' ' && !e.shiftKey) { e.preventDefault(); window.scrollBy({ top: window.innerHeight * 0.85, behavior: 'smooth' }); }
      if (e.key === ' ' &&  e.shiftKey) { e.preventDefault(); window.scrollBy({ top: -window.innerHeight * 0.85, behavior: 'smooth' }); }
      if (e.key === 'o' || e.key === 'Enter') {
        const all = visibleCards();
        const card = all[focusedIdx];
        const link = card?.querySelector<HTMLAnchorElement>('a[href]');
        if (link) { e.preventDefault(); window.open(link.href, '_blank', 'noopener'); }
      }
    }
    if (e.key === 'Escape') {
      if (inInput) active.blur();
      visibleCards().forEach(c => c.classList.remove('keyboard-focused'));
      focusedIdx = -1;
    }
  });
</script>

<style is:global>
  .person-card.keyboard-focused {
    outline: 2px solid var(--color-accent-emphasis);
    outline-offset: 2px;
  }
</style>
