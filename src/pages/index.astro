---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

import PeopleLayout from '../layouts/PeopleLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import HeroCard from '../components/HeroCard.astro';
import MaintainerCard from '../components/MaintainerCard.astro';
import InfoBox from '../components/InfoBox.astro';
import KubeConBanner from '../components/KubeConBanner.astro';
import { getActiveBanners } from '../lib/banners';

import changelogRaw from '../data/changelog.json';
import landscapeLogosRaw from '../data/landscape_logos.json';
import memorialList from '../data/memorial.json';
import tocList from '../data/toc.json';
import tabList from '../data/tab.json';
import leadershipList from '../data/leadership.json';
import gbList from '../data/gb.json';
import marketingList from '../data/marketing.json';
import staffSupportData from '../data/staff-support.json';
import peopleEmeritusList from '../data/people-emeritus.json';

// Load maintainers — generated by Go backend from cncf/foundation project-maintainers.csv.
// Falls back to empty array if the file hasn't been generated yet (first build).
interface SafeMaintainer {
  name: string;
  handle: string;
  company?: string;
  location?: string;
  countryFlag?: string;
  bio?: string;
  projects: string[];
  projectDetails?: { name: string; maturity: string }[];
  maturity: string;
  ownersUrl?: string;
  logoUrl?: string;
  yearsContributing?: number;
  updatedAt?: string;
}
let maintainerList: SafeMaintainer[] = [];
try {
  const maintainersPath = resolve('./src/data/maintainers.json');
  maintainerList = JSON.parse(readFileSync(maintainersPath, 'utf-8')) as SafeMaintainer[];
} catch {
  // maintainers.json not yet generated — skip maintainers tab silently
}

// Load heroes rotation — generated daily by Go backend from WriteHeroRotations.
// Falls back to empty if not yet generated (first build before Go has run).
interface HeroRotations {
  generatedAt?: string;
  everyone: Person[];
  ambassadors: Person[];
  kubestronauts: Person[];
  goldenKubestronauts: Person[];
  maintainers: SafeMaintainer[];
  cncfLeadership: Person[];
  emeritus?: Person[];
}
let heroRotations: HeroRotations = {
  everyone: [], ambassadors: [], kubestronauts: [], goldenKubestronauts: [],
  maintainers: [], cncfLeadership: [],
};
try {
  const heroesPath = resolve('./src/data/heroes.json');
  heroRotations = JSON.parse(readFileSync(heroesPath, 'utf-8')) as HeroRotations;
} catch {
  // heroes.json not yet generated — fall back to empty (no hero rows shown)
}

interface Change {
  field: string;
  from: string;
  to: string;
}

interface Person {
  name: string;
  handle?: string;
  github?: string;
  imageUrl?: string;
  bio?: string;
  pronouns?: string;
  company?: string;
  companyLandscapeUrl?: string;
  location?: string;
  linkedin?: string;
  twitter?: string;
  youtube?: string;
  website?: string;
  bluesky?: string;
  mastodon?: string;
  certDirectory?: string;
  category: string[];
  projects?: string[];
  avatarUrl?: string;
  contributions?: number;
  followers?: number;
  publicRepos?: number;
  countryFlag?: string;
  primaryBadge?: string;
}

interface Event {
  id: string;
  type: 'added' | 'removed' | 'updated';
  timestamp: string;
  person: Person;
  changes?: Change[];
}

const STATIC_COUNT = 30;

const events = changelogRaw as Event[];
const staticEvents = events.slice(0, STATIC_COUNT);
const landscapeLogos = landscapeLogosRaw as Record<string, string>;

function dateHeader(ts: string): string {
  const d = new Date(ts);
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}

const grouped: Map<string, Event[]> = new Map();
for (const e of staticEvents) {
  const key = dateHeader(e.timestamp);
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(e);
}

const baseUrl = (import.meta.env.BASE_URL as string).replace(/\/*$/, '/');
const feedUrl = `${baseUrl}feed.xml`;

const banners = await getActiveBanners();

const CATEGORY_ORDER = [
  'Kubestronaut',
  'Golden-Kubestronaut',
  'Ambassadors',
  'Technical Oversight Committee',
  'End User TAB',
  'Governing Board',
  'Staff',
  'Marketing Committee',
];
const CATEGORY_LABELS: Record<string, string> = {
  'Kubestronaut':                  'Kubestronauts',
  'Golden-Kubestronaut':           'Golden Kubestronauts',
  'Ambassadors':                   'Ambassadors',
  'Technical Oversight Committee': 'TOC Members',
  'End User TAB':                  'End User TAB',
  'Governing Board':               'Governing Board',
  'Staff':                         'Staff',
  'Marketing Committee':           'Marketing Committee',
};

interface SiteStats {
  total: number;
  added: number;
  removed: number;
  updated: number;
  countries: number;
  companies: number;
  categories: Record<string, number>;
}

let siteStats: SiteStats = {
  total: 0, added: 0, removed: 0, updated: 0,
  countries: 0, companies: 0, categories: {},
};
try {
  const statsPath = resolve('./src/data/stats.json');
  siteStats = JSON.parse(readFileSync(statsPath, 'utf-8')) as SiteStats;
} catch {
  // stats.json not yet generated — fall back to computing from events
  const uniquePeople = new Map<string, Person>();
  for (const e of events) {
    const key = e.person.github ?? e.person.name;
    if (!uniquePeople.has(key)) uniquePeople.set(key, e.person);
  }
  const peopleList = [...uniquePeople.values()];
  const countrySet = new Set(peopleList.map(p => (p.location ?? '').split(',').at(-1)?.trim() ?? '').filter(Boolean));
  const companySet = new Set(peopleList.map(p => p.company?.trim() ?? '').filter(Boolean));
  siteStats = {
    total: peopleList.length,
    added: events.filter(e => e.type === 'added').length,
    removed: events.filter(e => e.type === 'removed').length,
    updated: events.filter(e => e.type === 'updated').length,
    countries: countrySet.size,
    companies: companySet.size,
    categories: Object.fromEntries(
      CATEGORY_ORDER.map(cat => [cat, peopleList.filter(p => (p.category ?? []).includes(cat)).length])
    ),
  };
}

const categoryCounts = siteStats.categories;
const stats = { total: siteStats.total, added: siteStats.added, removed: siteStats.removed, updated: siteStats.updated };
const countries = siteStats.countries;
const companies = siteStats.companies;

const categories = [...new Set(events.flatMap(e => e.person.category ?? []))].sort();

// Per-category summary stats for the info banners
const TAB_CATEGORY_FILTER: Record<string, (cats: string[]) => boolean> = {
  'everyone':            ()    => true,
  'ambassadors':         cats  => cats.includes('Ambassadors'),
  'kubestronauts':       cats  => cats.includes('Kubestronaut'),
  'toc':                 cats  => cats.includes('Technical Oversight Committee'),
  'tab':                 cats  => cats.includes('End User TAB'),
  'governing-board':     cats  => cats.includes('Governing Board'),
  'staff':               cats  => cats.includes('Staff'),
};

function categoryStats(filterFn: (cats: string[]) => boolean) {
  const people = events
    .filter(e => filterFn(e.person.category ?? []))
    .map(e => e.person);
  const unique = new Map(people.map(p => [p.github ?? p.name, p]));
  const ps = [...unique.values()];
  const countries = new Set(
    ps.map(p => (p.location ?? '').split(',').at(-1)?.trim() ?? '').filter(Boolean)
  ).size;
  const projects = new Set(ps.flatMap(p => p.projects ?? [])).size;
  const orgs = new Set(ps.map(p => p.company ?? '').filter(Boolean)).size;
  return { total: ps.length, countries, projects, orgs };
}

const tabStats = Object.fromEntries(
  Object.entries(TAB_CATEGORY_FILTER).map(([tab, fn]) => [tab, categoryStats(fn)])
);

// TOC and TAB use static JSON hero displays — excluded from PersonCard alpha-feeds.
interface OrgMember { handle: string; name: string; title: string; }
// FlexOrgMember: same shape but handle is optional (for GB, marketing lists)
interface FlexOrgMember { handle?: string; name: string; title?: string; }
// EmeritusMember: people who left CNCF roles
interface EmeritusMember { handle?: string; name: string; removedDate?: string; category?: string[]; }
const tocMembers = tocList as OrgMember[];
const tabMembers = tabList as OrgMember[];
const leadershipMembers = leadershipList as OrgMember[];
const gbMembers = gbList as FlexOrgMember[];
const marketingMembers = marketingList as FlexOrgMember[];
const emeritusMembers = peopleEmeritusList as EmeritusMember[];

// CNCF Staff providing Support — keyed by tab name
interface StaffMember {
  handle?: string;
  name: string;
  imageUrl?: string;   // fallback avatar URL (e.g. cncf/people images CDN)
  profileUrl?: string; // fallback profile link (LinkedIn etc)
}
const TAB_STAFF = staffSupportData as Record<string, StaffMember[]>;

// Alphabetical tabs — deduplicated (most recent event per person), sorted by name
const ALPHA_TABS: Record<string, (cats: string[]) => boolean> = {
  'staff': cats => cats.includes('Staff'),
};

function alphabeticalPeople(filterFn: (cats: string[]) => boolean): Event[] {
  // events is newest-first; first occurrence = most recent event per person
  const seen = new Map<string, Event>();
  for (const e of events) {
    const key = e.person.github ?? e.person.name;
    if (!seen.has(key) && filterFn(e.person.category ?? [])) {
      seen.set(key, e);
    }
  }
  return [...seen.values()].sort((a, b) => a.person.name.localeCompare(b.person.name));
}

const alphaFeeds = Object.fromEntries(
  Object.entries(ALPHA_TABS).map(([tab, fn]) => [tab, alphabeticalPeople(fn)])
);


// Sort by UpdatedAt descending (most recently changed first).
const maintainerSorted = [...maintainerList].sort((a, b) => {
  const aTime = a.updatedAt ? new Date(a.updatedAt).getTime() : 0;
  const bTime = b.updatedAt ? new Date(b.updatedAt).getTime() : 0;
  return bTime - aTime;
});
const maintainerAlpha = maintainerSorted;
const MAINTAINER_STATIC = 20;

// Maintainer stats for sidebar
const maintainerProjects = new Set(maintainerList.flatMap(m => m.projects)).size;
const maintainerByMaturity: Record<string, number> = {};
for (const m of maintainerList) {
  const mat = m.maturity || 'Unknown';
  maintainerByMaturity[mat] = (maintainerByMaturity[mat] ?? 0) + 1;
}

// Emeritus flat list sorted by most recent removal date
const emeritusSorted = [...emeritusMembers].sort((a, b) => {
  const aDate = a.removedDate ? new Date(a.removedDate).getTime() : 0;
  const bDate = b.removedDate ? new Date(b.removedDate).getTime() : 0;
  return bDate - aDate;
});
---

<PeopleLayout pageTitle="CNCF People" feedUrl={feedUrl}>
  <Fragment slot="sidebar">
    <InfoBox
      title="Meet the Community"
      links={[
        { text: 'RSS Feed', url: feedUrl, rss: true },
        { text: 'cncf/people on GitHub', url: 'https://github.com/cncf/people', external: true },
        { text: 'castrojo/people-website', url: 'https://github.com/castrojo/people-website', external: true },
        { text: 'CNCF Releases (Firehose)', url: 'https://castrojo.github.io/firehose/', external: true },
      ]}
    >
      <p slot="description" class="info-description">
        Our projects and organizations are built by people. We are a global community spanning {countries} {countries === 1 ? 'country' : 'countries'} across the globe.
        <br /><br />
        Ready to start your journey? Answer the call, <a href="https://contribute.cncf.io/contributors/getting-started/" target="_blank" rel="noopener noreferrer" class="info-description-link">get started today</a>.
      </p>
    </InfoBox>

    {banners.length > 0 && <KubeConBanner banners={banners} />}

    <div class="stats">
      <h2 class="sidebar-heading stats-heading">Community</h2>
      <div class="stats-list">
        <div class="stat-row stat-row-total">
          <span class="stat-row-label">Total People</span>
          <span class="stat-row-value">{stats.total.toLocaleString()}</span>
        </div>
        <div class="stat-row-divider"></div>
        {CATEGORY_ORDER.filter(cat => categoryCounts[cat] > 0).map(cat => (
          <div class="stat-row">
            <span class="stat-row-label">{CATEGORY_LABELS[cat]}</span>
            <span class="stat-row-value">{categoryCounts[cat].toLocaleString()}</span>
          </div>
        ))}
        <div class="stat-row-divider"></div>
        <div class="stat-row">
          <span class="stat-row-label">Countries</span>
          <span class="stat-row-value">{countries.toLocaleString()}</span>
        </div>
        <div class="stat-row">
          <span class="stat-row-label">Organizations</span>
          <span class="stat-row-value">{companies.toLocaleString()}</span>
        </div>
      </div>
    </div>

    {maintainerList.length > 0 && (
      <div class="stats stats-maintainers" id="sidebar-maintainer-stats">
        <h2 class="sidebar-heading stats-heading">Maintainers</h2>
        <div class="stats-list">
          <div class="stat-row stat-row-total">
            <span class="stat-row-label">Total Maintainers</span>
            <span class="stat-row-value">{maintainerList.length.toLocaleString()}</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">Projects</span>
            <span class="stat-row-value">{maintainerProjects.toLocaleString()}</span>
          </div>
          <div class="stat-row-divider"></div>
          {(['Graduated', 'Incubating', 'Sandbox'] as const).filter(m => maintainerByMaturity[m]).map(m => (
            <div class="stat-row">
              <span class="stat-row-label">{m}</span>
              <span class="stat-row-value">{(maintainerByMaturity[m] ?? 0).toLocaleString()}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="sidebar-section">
      <h2 class="sidebar-heading">Filters</h2>
      <div class="filter-controls">
        <select id="type-filter" class="filter-select">
          <option value="">All people</option>
          <option value="added">Joined</option>
          <option value="removed">Emeritus</option>
          <option value="updated">Updated</option>
        </select>
        <select id="category-filter" class="filter-select">
          <option value="">All categories</option>
          {categories.map(cat => <option value={cat.toLowerCase()}>{cat}</option>)}
        </select>
      </div>
      <p id="filter-count" class="filter-count"></p>
    </div>

    <div class="sidebar-section made-with-love">
      <p>Made with <strong>&lt;3</strong> by your CNCF Projects Team</p>
    </div>
  </Fragment>

  <div id="feed" class="feed">
    <!-- Global search results overlay (shown when search query is non-empty) -->
    <div id="search-results-overlay" class="search-results-overlay" style="display:none" aria-live="polite">
      <div id="search-results-list" class="search-results-list"></div>
      <button id="clear-search-btn" class="clear-search-btn" type="button">Clear search</button>
    </div>

    <!-- Per-tab summary banners (shown/hidden by tab JS) -->
    {Object.entries(tabStats).map(([tab, s]) => (
      <div class="category-summary" data-tab-summary={tab} style={tab !== 'everyone' ? 'display:none' : ''}>
        <span>
          <strong>{s.total.toLocaleString()}</strong> {s.total === 1 ? 'individual' : 'individuals'}
          {s.countries > 0 && <> across <strong>{s.countries}</strong> {s.countries === 1 ? 'country' : 'countries'}</>}
          {s.projects > 0 && <>, working on <strong>{s.projects}</strong> {s.projects === 1 ? 'project' : 'projects'}</>}
          {s.orgs > 0 && <>, representing <strong>{s.orgs}</strong> {s.orgs === 1 ? 'organization' : 'organizations'}</>}.
        </span>
      </div>
    ))}
    {maintainerList.length > 0 && (
      <div class="category-summary" id="maintainer-summary" style="display:none">
        <span>
          <strong>{maintainerList.length.toLocaleString()}</strong> maintainers across <strong>{maintainerProjects.toLocaleString()}</strong> projects — Graduated, Incubating, and Sandbox.
        </span>
      </div>
    )}

    <!-- Per-tab hero rows: shown when the matching tab is active (managed by applyTab) -->
    {heroRotations.everyone.length > 0 && (
      <section class="tab-heroes-section" data-tab-heroes="everyone" style="display:none">
        <h2 class="tab-heroes-heading">Community Members of the Day</h2>
        <div class="heroes-grid">
          {heroRotations.everyone.map(p => (
            <HeroCard person={p} label={p.category?.[0] ?? 'Community'} categoryKey={p.category?.[0] ?? 'Community'} baseUrl={baseUrl} />
          ))}
        </div>
      </section>
    )}

    {heroRotations.ambassadors.length > 0 && (
      <section class="tab-heroes-section" data-tab-heroes="ambassadors" style="display:none">
        <h2 class="tab-heroes-heading">Ambassadors of the Day</h2>
        <div class="heroes-grid">
          {heroRotations.ambassadors.map(p => (
            <HeroCard person={p} label="Ambassador" categoryKey="Ambassadors" baseUrl={baseUrl} />
          ))}
        </div>
      </section>
    )}
    {TAB_STAFF['ambassadors'] && (
      <section class="staff-support-section" data-tab-heroes="ambassadors" style="display:none">
        <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
        <div class="staff-support-list">
          {TAB_STAFF['ambassadors'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {heroRotations.goldenKubestronauts.length > 0 && (
      <section class="tab-heroes-section" data-tab-heroes="kubestronauts" style="display:none">
        <h2 class="tab-heroes-heading">Golden Kubestronauts of the Day</h2>
        <div class="heroes-grid">
          {heroRotations.goldenKubestronauts.map(p => (
            <HeroCard person={p} label="Golden Kubestronaut" categoryKey="Golden-Kubestronaut" baseUrl={baseUrl} />
          ))}
        </div>
      </section>
    )}
    {heroRotations.kubestronauts.length > 0 && (
      <section class="tab-heroes-section" data-tab-heroes="kubestronauts" style="display:none">
        <h2 class="tab-heroes-heading">Kubestronauts of the Day</h2>
        <div class="heroes-grid">
          {heroRotations.kubestronauts.map(p => (
            <HeroCard person={p} label="Kubestronaut" categoryKey="Kubestronaut" baseUrl={baseUrl} />
          ))}
        </div>
      </section>
    )}
    {TAB_STAFF['kubestronauts'] && (
      <section class="staff-support-section" data-tab-heroes="kubestronauts" style="display:none">
        <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
        <div class="staff-support-list">
          {TAB_STAFF['kubestronauts'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Timeline feed: recent-first, date-grouped (hidden for alpha tabs) -->
    <div id="timeline-feed" data-static-count={STATIC_COUNT} data-base-url={baseUrl.replace(/\/$/, '')}>
      <h2 class="changelog-heading">Changelog</h2>
      {[...grouped.entries()].map(([date, dayEvents]) => (
        <section class="day-group" data-date={date}>
          <h2 class="day-header">{date}</h2>
          {dayEvents.map(event => (
            <PersonCard
              id={event.id}
              type={event.type}
              timestamp={event.timestamp}
              person={event.person}
              changes={event.changes}
              landscapeLogos={landscapeLogos}
            />
          ))}
        </section>
      ))}

      {staticEvents.length === 0 && (
        <div class="empty-state">
          <p>No activity yet — check back after the first daily sync.</p>
        </div>
      )}
    </div>

    <!-- CNCF Leadership heroes: rendered directly from leadership.json (not via heroRotations) -->
    <div class="alpha-feed" style="display:none" data-alpha-tab="staff">
      <section class="tab-heroes-section">
        <h2 class="tab-heroes-heading">CNCF Leadership</h2>
        <div class="heroes-grid">
          {leadershipMembers.map(m => (
            <HeroCard
              person={{ name: m.name, handle: m.handle, github: `https://github.com/${m.handle}`, avatarUrl: `https://avatars.githubusercontent.com/${m.handle}` }}
              label={m.title}
              categoryKey="Staff"
              baseUrl={baseUrl}
            />
          ))}
        </div>
      </section>
    </div>

    <!-- Alpha feeds: deduplicated, alphabetical (staff, everyone, and category roll-up tabs) -->
    {Object.entries(alphaFeeds).map(([tab, tabEvents]) => (
      <div id={`alpha-feed-${tab}`} class="alpha-feed" style="display:none" data-alpha-tab={tab}>
        {tabEvents.map(event => (
          <PersonCard
            id={`alpha-${event.id}`}
            type={event.type}
            timestamp={event.timestamp}
            person={event.person}
            changes={event.changes}
            landscapeLogos={landscapeLogos}
          />
        ))}
      </div>
    ))}
    <div class="alpha-feed" style="display:none" data-alpha-tab="toc">
      <section class="tab-heroes-section">
        <h2 class="tab-heroes-heading">Technical Oversight Committee</h2>
        <div class="heroes-grid">
          {tocMembers.map(m => (
            <HeroCard
              person={{ name: m.name, handle: m.handle, github: `https://github.com/${m.handle}`, avatarUrl: `https://avatars.githubusercontent.com/${m.handle}` }}
              label={m.title}
              categoryKey="TOC"
              baseUrl={baseUrl}
            />
          ))}
        </div>
      </section>
      <section class="staff-support-section">
        <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
        <div class="staff-support-list">
          {TAB_STAFF['toc'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>

    <!-- TAB hero display -->
    <div class="alpha-feed" style="display:none" data-alpha-tab="tab">
      <section class="tab-heroes-section">
        <h2 class="tab-heroes-heading">End User Technical Advisory Board</h2>
        <div class="heroes-grid">
          {tabMembers.map(m => (
            <HeroCard
              person={{ name: m.name, handle: m.handle, github: `https://github.com/${m.handle}`, avatarUrl: `https://avatars.githubusercontent.com/${m.handle}` }}
              label={m.title}
              categoryKey="TAB"
              baseUrl={baseUrl}
            />
          ))}
        </div>
      </section>
      <section class="staff-support-section">
        <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
        <div class="staff-support-list">
          {TAB_STAFF['tab'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>

    <!-- Governing Board hero display -->
    <div class="alpha-feed" style="display:none" data-alpha-tab="governing-board">
      <section class="tab-heroes-section">
        <h2 class="tab-heroes-heading">Governing Board</h2>
        <div class="heroes-grid">
          {gbMembers.filter(m => m.handle).map(m => (
            <HeroCard
              person={{ name: m.name, handle: m.handle, github: `https://github.com/${m.handle}`, avatarUrl: `https://avatars.githubusercontent.com/${m.handle}` }}
              label={m.title ?? 'Board Member'}
              categoryKey="Board"
              baseUrl={baseUrl}
            />
          ))}
        </div>
      </section>
      {TAB_STAFF['governing-board'] && (
        <section class="staff-support-section">
          <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
          <div class="staff-support-list">
            {TAB_STAFF['governing-board'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Marketing Committee hero display -->
    <div class="alpha-feed" style="display:none" data-alpha-tab="marketing">
      <section class="tab-heroes-section">
        <h2 class="tab-heroes-heading">Marketing Committee</h2>
        <div class="heroes-grid">
          {marketingMembers.filter(m => m.handle).map(m => (
            <HeroCard
              person={{ name: m.name, handle: m.handle, github: `https://github.com/${m.handle}`, avatarUrl: `https://avatars.githubusercontent.com/${m.handle}` }}
              label={m.title ?? 'Marketing'}
              categoryKey="Marketing"
              baseUrl={baseUrl}
            />
          ))}
        </div>
      </section>
      {TAB_STAFF['marketing'] && (
        <section class="staff-support-section">
          <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
          <div class="staff-support-list">
            {TAB_STAFF['marketing'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Memorial feed (hidden until Memorial tab is selected) -->
    <div id="memorial-feed" style="display:none">
      <p class="memorial-intro">In memory of members of our community who have passed. Their contributions continue to shape the CNCF ecosystem.</p>
      <div class="memorial-heroes-grid">
        {memorialList.map(person => (
          <HeroCard
            person={{
              name: person.name,
              handle: person.github ? person.github.replace('https://github.com/', '') : undefined,
              github: person.github,
              avatarUrl: person.avatar,
              company: person.company,
            }}
            label={person.role ?? 'Community Member'}
            categoryKey="Memorial"
            baseUrl={baseUrl}
          />
        ))}
      </div>
    </div>

    <!-- Contributors Emeritus feed -->
    <div class="alpha-feed" style="display:none" data-alpha-tab="emeritus">
      <p class="memorial-intro">When the work is done, the long walk beckons ...</p>
      {(heroRotations.emeritus ?? []).length > 0 && (
        <section class="tab-heroes-section">
          <h2 class="tab-heroes-heading">Contributors Emeritus</h2>
          <div class="heroes-grid">
            {(heroRotations.emeritus ?? []).map(m => (
              <HeroCard
                person={{ name: m.name, handle: m.handle, github: m.handle ? `https://github.com/${m.handle}` : undefined, avatarUrl: m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : undefined }}
                label="Legend"
                categoryKey="Emeritus"
                baseUrl={baseUrl}
              />
            ))}
          </div>
        </section>
      )}
      {emeritusSorted.map(e => e.handle
        ? <PersonCard
            id={`emeritus-${e.handle}`}
            type="removed"
            timestamp={e.removedDate ?? ''}
            person={{ name: e.name, handle: e.handle, github: `https://github.com/${e.handle}`, avatarUrl: `https://avatars.githubusercontent.com/${e.handle}`, category: e.category ?? [] }}
            landscapeLogos={landscapeLogos}
          />
        : <div class="emeritus-name-row">{e.name}</div>
      )}
    </div>

    <!-- Maintainers feed (hidden until Maintainers tab is selected) -->
    <div id="maintainer-feed" style="display:none" data-alpha-tab="maintainers">
      {heroRotations.maintainers.length > 0 && (
        <section class="tab-heroes-section">
          <h2 class="tab-heroes-heading">Maintainers of the Day</h2>
          <div class="heroes-grid">
            {heroRotations.maintainers.map(m => (
              <HeroCard
                person={{ name: m.name, handle: m.handle, github: m.handle ? `https://github.com/${m.handle}` : undefined, avatarUrl: m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : undefined, imageUrl: m.logoUrl, location: m.location, countryFlag: m.countryFlag, company: m.company }}
                label="Maintainer"
                categoryKey="Maintainer"
                baseUrl={baseUrl}
              />
            ))}
          </div>
        </section>
      )}
      <section class="staff-support-section">
        <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
        <div class="staff-support-list">
          {TAB_STAFF['maintainers'].map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')} alt={m.name} class="staff-support-avatar" loading="lazy" />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
      <div class="maintainer-list-section">
        {maintainerAlpha.slice(0, MAINTAINER_STATIC).map(m => (
          <MaintainerCard
            maintainer={m}
            projectLogos={Object.fromEntries(
              m.projects.map(p => [p, (landscapeLogosRaw as Record<string, string>)[p] ?? (landscapeLogosRaw as Record<string, string>)[p.toLowerCase()] ?? ''])
            )}
          />
        ))}
      </div>
    </div>
  </div>
</PeopleLayout>

