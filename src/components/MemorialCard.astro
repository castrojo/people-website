---
interface Memorial {
  name:    string;
  slug:    string;
  url:     string;
  github:  string | null;
  avatar:  string | null;
  role:    string | null;
  company: string | null;
}
interface Props { person: Memorial; }
const { person } = Astro.props;

const initials = person.name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
---

<a href={person.url} target="_blank" rel="noopener noreferrer" class="memorial-card">
  <div class="memorial-avatar-wrap">
    {person.avatar
      ? <img src={person.avatar} alt={person.name} class="memorial-avatar-img" loading="lazy" />
      : <div class="memorial-avatar-placeholder" aria-hidden="true">{initials}</div>
    }
  </div>
  <div class="memorial-info">
    <span class="memorial-name">{person.name}</span>
    {person.role && <span class="memorial-role">{person.role}</span>}
    {person.company && <span class="memorial-company">{person.company}</span>}
    <div class="memorial-footer">
      {person.github && <span class="memorial-github">GitHub ↗</span>}
      <span class="memorial-read">Read memorial ↗</span>
    </div>
  </div>
</a>

<style>
  .memorial-card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    background: var(--color-bg-default);
    border: 1px solid var(--color-border-default);
    border-left: 3px solid #6b7280;
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    margin-bottom: 0.625rem;
  }
  .memorial-card:hover {
    border-left-color: #9ca3af;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .memorial-avatar-wrap { flex-shrink: 0; }

  .memorial-avatar-img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border-default);
    filter: grayscale(30%);
  }

  .memorial-avatar-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #374151;
    color: #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .memorial-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .memorial-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .memorial-role {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .memorial-company {
    font-size: 0.775rem;
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .memorial-footer {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.3rem;
  }

  .memorial-github,
  .memorial-read {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .memorial-card:hover .memorial-read,
  .memorial-card:hover .memorial-github {
    color: var(--color-accent);
  }
</style>
